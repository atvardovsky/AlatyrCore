{
  "schema_version": 1,
  "catalog_kind": "target-operation-catalog",
  "project": "{PROJECT_NAME}",
  "compact_help": ".ai/assistant/help.md",
  "human_reference": ".ai/assistant/help-reference.md",
  "routing_flow": ".ai/assistant/flows/operation-routing.flow.md",
  "health_flow": ".ai/assistant/flows/adapter-health.flow.md",
  "pre_change_preview": ".ai/assistant/templates/pre-change-preview.md",
  "module_profile": ".ai/assistant/module-profile.md",
  "fallback_operation": "help",
  "operations": [
    {
      "id": "help",
      "title": "Alatyr",
      "summary": "Show adapter state and the most relevant available actions.",
      "use_when": ["bare Alatyr request", "operation help", "ambiguous request"],
      "context_profiles": [],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/operation-routing.flow.md",
      "minimum_inputs": ["goal or suspected task area when known"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["Alatyr", "Alatyr help"],
      "final_evidence": ["adapter state evidence status", "relevant operations", "next safe action"]
    },
    {
      "id": "adapter-health",
      "title": "Adapter health",
      "summary": "Inspect current adapter structure and return prioritized repair routes without editing.",
      "use_when": ["adapter status", "adapter doctor", "suspected adapter breakage"],
      "context_profiles": ["framework-upgrade"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/adapter-health.flow.md",
      "minimum_inputs": ["optional health scope"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["Alatyr status", "Alatyr doctor"],
      "final_evidence": ["health state", "evidence revision or time", "up to three repair operations"]
    },
    {
      "id": "create-project-blueprint",
      "title": "Create project blueprint",
      "summary": "Create, repair, or recheck blueprint-equivalent sources from target evidence.",
      "use_when": ["missing blueprint", "stale blueprint", "source-of-truth repair"],
      "context_profiles": ["business-change", "architecture-change"],
      "required_module": "blueprint-change",
      "flow": ".ai/assistant/flows/project-blueprint-creation.flow.md",
      "minimum_inputs": ["blueprint scope", "non-goals"],
      "allowed_actions": ["read-only", "docs-only", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["create blueprint", "repair blueprint", "recheck blueprint"],
      "final_evidence": ["sources inspected", "facts recorded", "gaps and approvals"]
    },
    {
      "id": "recheck-after-installation",
      "title": "Recheck installation",
      "summary": "Verify a newly installed target adapter against repository evidence.",
      "use_when": ["post-install recheck", "installation verification"],
      "context_profiles": ["framework-upgrade"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/adapter-recheck.flow.md",
      "minimum_inputs": ["installation note or known gaps"],
      "allowed_actions": ["read-only", "adapter-only", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["check Alatyr after installation", "recheck installation"],
      "final_evidence": ["adapter findings", "validation", "remaining gaps"]
    },
    {
      "id": "recheck-after-framework-update",
      "title": "Recheck framework update",
      "summary": "Assess and repair target adapter impact from an Alatyr Core update.",
      "use_when": ["framework update", "baseline change", "migration assessment"],
      "context_profiles": ["framework-upgrade"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/adapter-recheck.flow.md",
      "minimum_inputs": ["update source or changed framework baseline"],
      "allowed_actions": ["read-only", "adapter-only", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["update Alatyr", "recheck Alatyr update"],
      "final_evidence": ["migration impact", "adapter changes", "validation and residual risk"]
    },
    {
      "id": "product-change",
      "title": "Product change",
      "summary": "Carry an accepted business, architecture, data, runtime, or public-contract change through all affected surfaces.",
      "use_when": ["business rule change", "architecture change", "data contract change", "public behavior change"],
      "context_profiles": ["business-change", "architecture-change", "data-change", "security-sensitive"],
      "required_module": "blueprint-change",
      "flow": ".ai/assistant/flows/blueprint-driven-change.flow.md",
      "minimum_inputs": ["change intent", "non-goals", "approval constraints"],
      "allowed_actions": ["read-only", "docs-only", "code-and-tests", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["change business rule", "product change"],
      "final_evidence": ["changed facts and owners", "repair set", "validation and residual risk"]
    },
    {
      "id": "large-task",
      "title": "Large task",
      "summary": "Coordinate bounded workstreams, checkpoints, and convergence for large or resumable work.",
      "use_when": ["multiple workstreams", "cross-boundary task", "resumable task", "context budget exceeded"],
      "context_profiles": [],
      "required_module": "large-task-orchestration",
      "flow": ".ai/assistant/flows/large-task-orchestration.flow.md",
      "minimum_inputs": ["goal", "non-goals", "affected areas", "allowed actions"],
      "allowed_actions": ["read-only", "docs-only", "adapter-only", "code-and-tests", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["plan large task", "continue large task", "resume Alatyr task"],
      "final_evidence": ["workstream state", "context receipts", "global convergence"]
    },
    {
      "id": "team-status",
      "title": "Team status",
      "summary": "Report current team work, stale claims, conflicts, handoffs, and review state without editing.",
      "use_when": ["team status", "active task overview", "coordination attention"],
      "context_profiles": [],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-task-coordination.flow.md",
      "minimum_inputs": ["optional team, area, actor, or task scope"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["Alatyr team status"],
      "final_evidence": ["evidence revision", "active and blocked tasks", "up to three coordination actions"]
    },
    {
      "id": "team-task",
      "title": "Team task coordination",
      "summary": "Start, claim, checkpoint, or release a team task without broadening project-change scope.",
      "use_when": ["start team task", "claim task", "checkpoint task", "release task"],
      "context_profiles": [],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-task-coordination.flow.md",
      "minimum_inputs": ["action", "task ID or goal", "actor ID", "allowed actions"],
      "allowed_actions": ["read-only", "adapter-only"],
      "preview": "never",
      "aliases": ["Alatyr start", "Alatyr claim", "Alatyr checkpoint", "Alatyr release"],
      "final_evidence": ["task and actor IDs", "claim or checkpoint state", "backend synchronization and next action"]
    },
    {
      "id": "team-conflict-review",
      "title": "Team conflict review",
      "summary": "Detect active-task overlap from facts, owners, contracts, dependencies, and secondary file evidence.",
      "use_when": ["concurrent task conflict", "changed fact overlap", "task sequencing decision"],
      "context_profiles": [],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-task-coordination.flow.md",
      "minimum_inputs": ["task ID or proposed task scope"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["Alatyr conflicts"],
      "final_evidence": ["overlap classification", "conflicting tasks and facts", "coordination or sequencing action"]
    },
    {
      "id": "team-handoff",
      "title": "Team handoff",
      "summary": "Checkpoint and hand a task to another actor or role with bounded resume context.",
      "use_when": ["task handoff", "assistant or developer change", "session transfer"],
      "context_profiles": [],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-handoff.flow.md",
      "minimum_inputs": ["task ID", "source actor", "destination actor or role", "handoff reason"],
      "allowed_actions": ["read-only", "adapter-only"],
      "preview": "never",
      "aliases": ["Alatyr handoff"],
      "final_evidence": ["checkpoint and handoff references", "acceptance state", "resume context and residual risk"]
    },
    {
      "id": "team-decision",
      "title": "Team decision",
      "summary": "Structure a priority, business, architecture, data, security, or adapter decision and route accepted facts to their owners.",
      "use_when": ["team decision", "business or architecture discussion", "priority conflict", "option tradeoff"],
      "context_profiles": ["business-change", "architecture-change", "data-change", "security-sensitive"],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-decision.flow.md",
      "minimum_inputs": ["decision question", "decision type", "affected facts or task IDs"],
      "allowed_actions": ["read-only", "docs-only", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["Alatyr decision", "Alatyr discuss"],
      "final_evidence": ["decision owner and options", "selected result or unresolved state", "canonical destination and follow-up"]
    },
    {
      "id": "team-review",
      "title": "Team review",
      "summary": "Review a task against current scope, concurrent work, required reviewers, validation, and logical integrity.",
      "use_when": ["team task review", "cross-actor review", "review before merge check"],
      "context_profiles": ["code-local", "business-change", "architecture-change", "data-change", "security-sensitive"],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-review.flow.md",
      "minimum_inputs": ["task ID", "review scope", "current head and base revisions"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["Alatyr review"],
      "final_evidence": ["findings by severity", "overlap and reviewer evidence", "validation integrity and next owners"]
    },
    {
      "id": "team-merge-check",
      "title": "Team merge check",
      "summary": "Classify revision-bound merge readiness without performing a merge.",
      "use_when": ["merge readiness", "pre-merge coordination check", "final team gate"],
      "context_profiles": ["code-local", "business-change", "architecture-change", "data-change", "security-sensitive"],
      "required_module": "team-collaboration",
      "flow": ".ai/assistant/flows/team-review.flow.md",
      "minimum_inputs": ["task ID", "current head revision", "current base revision"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["Alatyr merge check"],
      "final_evidence": ["readiness state", "revision-bound review and approval evidence", "blockers residual risk and next actor"]
    },
    {
      "id": "logical-integrity-review",
      "title": "Logical integrity review",
      "summary": "Check changed facts, invariants, owners, and companion surfaces for consistency.",
      "use_when": ["suspected cross-surface drift", "changed invariant", "review item cluster"],
      "context_profiles": ["code-local", "business-change", "architecture-change", "data-change", "security-sensitive", "ai-infrastructure"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/logical-integrity-review.flow.md",
      "minimum_inputs": ["changed fact, suspected drift, or files to inspect"],
      "allowed_actions": ["read-only", "docs-only", "adapter-only", "code-and-tests", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["check integrity", "logical integrity review"],
      "final_evidence": ["invariants", "repair set", "validation and residual risk"]
    },
    {
      "id": "ai-infrastructure-inventory",
      "title": "AI infrastructure inventory",
      "summary": "Report existing target-owned AI infrastructure and unresolved inventory gaps.",
      "use_when": ["list AI infrastructure", "check existing skills prompts gates or tools"],
      "context_profiles": ["ai-infrastructure"],
      "required_module": "ai-infrastructure",
      "flow": ".ai/assistant/flows/ai-infrastructure-inventory.flow.md",
      "minimum_inputs": ["inventory scope", "target assistant surfaces"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["alatyr-ai-inventory"],
      "final_evidence": ["inventory", "coverage gaps", "no-change confirmation"]
    },
    {
      "id": "ai-infrastructure-recommendation",
      "title": "AI infrastructure recommendation",
      "summary": "Recommend evidence-based additions or improvements without changing infrastructure.",
      "use_when": ["suggest AI infrastructure", "improve existing AI item", "repeated development friction"],
      "context_profiles": ["ai-infrastructure"],
      "required_module": "ai-infrastructure",
      "flow": ".ai/assistant/flows/ai-infrastructure-recommendation.flow.md",
      "minimum_inputs": ["bounded project problem or item ID", "available outcome evidence"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["alatyr-suggest-ai", "alatyr-improve-ai"],
      "final_evidence": ["recommendation", "quality cost and maintenance impact", "acceptance criteria"]
    },
    {
      "id": "skill-adaptation",
      "title": "AI infrastructure adaptation",
      "summary": "Review or adapt skills, prompts, gates, tools, bridges, wrappers, and related sources.",
      "use_when": ["adapt external AI source", "add AI infrastructure", "change AI infrastructure item"],
      "context_profiles": ["ai-infrastructure", "security-sensitive"],
      "required_module": "ai-infrastructure",
      "flow": ".ai/assistant/flows/skill-adaptation.flow.md",
      "minimum_inputs": ["source", "item type", "intended use", "assistant surfaces", "permissions"],
      "allowed_actions": ["read-only", "adapter-only", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["alatyr-adaptation", "alatyr-add-ai"],
      "final_evidence": ["provenance", "rejected source instructions", "adaptation and validation"]
    },
    {
      "id": "drift-review",
      "title": "Drift review",
      "summary": "Find stale owners, derived surfaces, or adapter claims without assuming repair scope.",
      "use_when": ["suspected source-of-truth drift", "stale docs diagrams gates prompts or bridges"],
      "context_profiles": ["docs-local", "code-local", "framework-upgrade"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/logical-integrity-review.flow.md",
      "minimum_inputs": ["drift area or recently changed facts"],
      "allowed_actions": ["read-only", "docs-only", "adapter-only", "code-and-tests", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["review drift", "find stale Alatyr facts"],
      "final_evidence": ["drift findings", "owners", "repair recommendation"]
    },
    {
      "id": "documentation-sync",
      "title": "Documentation sync",
      "summary": "Synchronize documentation and other derived explanatory surfaces after a fact changes.",
      "use_when": ["documentation drift", "diagram sync", "companion assistant artifact sync"],
      "context_profiles": ["docs-local", "ai-infrastructure"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/documentation-sync.flow.md",
      "minimum_inputs": ["changed fact", "canonical owner"],
      "allowed_actions": ["read-only", "docs-only", "adapter-only", "full-with-approval"],
      "preview": "risk-gated",
      "aliases": ["sync documentation", "sync diagrams"],
      "final_evidence": ["owners and derived surfaces", "updated artifacts", "validation"]
    },
    {
      "id": "adapter-maturity-review",
      "title": "Adapter maturity review",
      "summary": "Assess task-specific adapter capability, blockers, and evidence gaps.",
      "use_when": ["adapter readiness review", "task-specific maturity", "broad capability review"],
      "context_profiles": ["framework-upgrade"],
      "required_module": "core-profile",
      "flow": ".ai/assistant/flows/adapter-recheck.flow.md",
      "minimum_inputs": ["task scope", "maturity concern"],
      "allowed_actions": ["read-only"],
      "preview": "never",
      "aliases": ["check Alatyr maturity", "review adapter readiness"],
      "final_evidence": ["task maturity", "blocking criteria", "next repair operations"]
    }
  ]
}
